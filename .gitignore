# dependencies — reinstalled with `npm install`
/node_modules

# next.js build output — regenerated by `npm run dev` / `npm run build`
/.next
/out

# production build
/build

# misc OS / editor files
.DS_Store
*.pem

# debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# environment variables (secrets — never commit these)
.env*
